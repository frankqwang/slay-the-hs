# ============================================================
# Slay the Spire 2 - GDRE 反编译项目 .gitignore
# 只追踪代码 & 配置，忽略所有二进制资源
# ============================================================

# === Godot 引擎缓存 ===
.godot/

# === 二进制资源（大文件） ===
#images/
#models/
#animations/
#materials/
#fonts/
#shaders/
#themes/
#banks/
debug_audio/
icudt_godot.dat

# === 原生 DLL / 引用程序集 ===
bin/
_mono_referenced_assemblies/
steam/

# === .NET 构建产物 ===
packages.lock.json

# === JetBrains Rider ===
.idea/
*.DotSettings.user
RiderTestRunner/

# === GDRE 转换缓存 ===
.autoconverted/

# === OS 垃圾 ===
Thumbs.db
Desktop.ini
.DS_Store

#localization
addons
Exports

.vscode